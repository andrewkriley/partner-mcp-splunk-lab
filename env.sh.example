# Claude Code skill credentials — copy to .claude/env.sh in this repo
# (.claude/env.sh is gitignored — never commit secrets.)
#
# This file is sourced at runtime by the splunk-lab-dashboard-gen skill when
# calling the Splunk REST API directly from your machine. Docker Compose
# only reads .env — skills do not see .env automatically.
#
# Setup:
#   cp env.sh.example .claude/env.sh
#   chmod 600 .claude/env.sh
#   # then edit the values below (or run ./install.sh and accept the skill prompt)

# ── Splunk REST API ────────────────────────────────────────────────────────
# Host where Splunk is running. For the local lab this is always localhost.
export SPLUNK_HOST=localhost

# Basic auth credentials (matches SPLUNK_PASSWORD in your .env file).
export SPLUNK_USER=admin
export SPLUNK_PASS=Chang3d!     # replace with your actual SPLUNK_PASSWORD

# REST authentication token (JWT, audience splunkd). install.sh mints this
# automatically when you create .claude/env.sh (after Splunk is up). Tools
# that support Bearer auth should prefer this over SPLUNK_USER/SPLUNK_PASS.
# You can also create tokens in Splunk Web: Settings → Tokens → New Token.
export SPLUNK_API_TOKEN=

# ── Hugging Face API ───────────────────────────────────────────────────────
# Token (hf_...) for HuggingFace Inference API. Used by the splunk-lab-dashboard-gen
# skill for AI background images when this file is sourced in the same shell as
# Claude Code / Bash, and matches what many HuggingFace MCP setups expect.
# Create: https://huggingface.co/settings/tokens
export HF_TOKEN=
